{
  "permissions": {
    "allow": [
      "Bash(bun x:*)",
      "Bash(openspec new:*)",
      "Bash(openspec status:*)",
      "Bash(openspec instructions:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun fix --skip=correctness/noUnusedImports"
          }
        ]
      }
    ]
  }
}
